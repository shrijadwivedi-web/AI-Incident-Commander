{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AlertEvent",
  "type": "object",
  "required": [
    "alert_id",
    "source",
    "service_name",
    "severity",
    "summary",
    "status",
    "raw_payload",
    "occurred_at"
  ],
  "properties": {
    "alert_id": { "type": "string", "format": "uuid" },
    "source": { "type": "string" },
    "service_name": { "type": "string" },
    "severity": { "type": "string" },
    "summary": { "type": "string" },
    "status": { "type": "string" },
    "raw_payload": { "type": "object" },
    "occurred_at": { "type": "string", "format": "date-time" }
  }
}
